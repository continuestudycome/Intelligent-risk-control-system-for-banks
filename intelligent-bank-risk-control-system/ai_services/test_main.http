###

POST http://127.0.0.1:8000/rule/fraud/simulate
Content-Type: application/json

{
  "thresholds": {
    "absoluteHighAmount": 85000,
    "remoteAmountMin": 28000,
    "probeMaxAmount": 500,
    "probeCountMedium": 4,
    "mlScoreHigh": 0.68,
    "rulesEnabled": {
      "RULE_AMOUNT_EXTREME": true,
      "RULE_REMOTE_LARGE_TX": true,
      "RULE_FREQ_SMALL_PROBE": true,
      "RULE_ML_ANOMALY_HIGH": true
    }
  },
  "samples": [
    {"amount": 90000, "sameProvince": true, "probeCount": 0, "mlScore": 0.2},
    {"amount": 30000, "sameProvince": false, "probeCount": 0, "mlScore": 0.2}
  ]
}

