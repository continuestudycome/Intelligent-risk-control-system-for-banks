# 在 ai_services 目录: uvicorn app.main:app --reload --host 0.0.0.0 --port 8000

GET http://127.0.0.1:8000/
Accept: application/json

###

GET http://127.0.0.1:8000/hello/User
Accept: application/json

###

POST http://127.0.0.1:8000/credit/limit-recommend
Content-Type: application/json

{
  "risk_level": "A",
  "blacklist": false,
  "txn_count_90d": 50,
  "asset_amount_wan": 600,
  "min_total": 10000,
  "max_total": 2000000
}

###

POST http://127.0.0.1:8000/rule/fraud/validate
Content-Type: application/json

{
  "rules": [
    {
      "ruleCode": "RULE_AMOUNT_EXTREME",
      "ruleCondition": "{\"absoluteHighAmount\":85000}"
    },
    {
      "ruleCode": "RULE_REMOTE_LARGE_TX",
      "ruleCondition": "{\"remoteAmountMin\":28000}"
    }
  ]
}

###

POST http://127.0.0.1:8000/chat/rag
Content-Type: application/json

{
  "question": "交易被拦截怎么办",
  "history": [],
